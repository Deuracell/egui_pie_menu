use egui::{Pos2, Rect, Ui, Vec2, Color32, Key};
use std::collections::HashMap;
use std::time::{Duration, Instant};

#[derive(Debug)]
pub enum PieMenuResponse {
    Selected(String),
    Dismissed,
    None,
}

pub struct PieMenuSettings {
    pub radius: f32,
    pub animation_duration: Duration,
    pub threshold: f32,
    pub key_timeout: Duration,
}

impl Default for PieMenuSettings {
    fn default() -> Self {
        Self {
            radius: 100.0,
            animation_duration: Duration::from_millis(6),
            threshold: 12.0,
            key_timeout: Duration::from_millis(20),
        }
    }
}

pub struct PieMenuButton {
    pub label: String,
    pub direction: Vec2,
    pub color: Color32,
}

pub struct PieMenuConfig {
    pub buttons: Vec<(&'static str, &'static str, Color32)>,
    pub trigger_key: Key,
}

pub struct PieMenuManager {
    settings: PieMenuSettings,
    active_menu: Option<PieMenu>,
    key_was_down: bool,
}

pub struct PieMenu {
    buttons: HashMap<String, PieMenuButton>,
    open_time: Instant,
    selected_index: Option<String>,
    position: Pos2,
    settings: PieMenuSettings,
    key_held: bool,
}

impl PieMenu {
    /// Cardinal direction mappings.
    fn direction_map() -> HashMap<&'static str, Vec2> {
        HashMap::from([
            ("N", Vec2::new(0.0, -1.0)),
            ("NE", Vec2::new(1.0, -1.0)),
            ("E", Vec2::new(1.0, 0.0)),
            ("SE", Vec2::new(1.0, 1.0)),
            ("S", Vec2::new(0.0, 1.0)),
            ("SW", Vec2::new(-1.0, 1.0)),
            ("W", Vec2::new(-1.0, 0.0)),
            ("NW", Vec2::new(-1.0, -1.0)),
        ])
    }

    /// Creates a new pie menu with user-assigned cardinal directions.
    pub fn new_with_buttons(labels: Vec<(&str, &str, Color32)>) -> Self {
        let direction_map = Self::direction_map();
        let buttons = labels
            .into_iter()
            .filter_map(|(label, dir, color)| {
                direction_map.get(dir).map(|&direction| {
                    (dir.to_string(), PieMenuButton {
                        label: label.to_string(),
                        direction,
                        color,
                    })
                })
            })
            .collect();

        Self {
            buttons,
            open_time: Instant::now(),
            selected_index: None,
            position: Pos2::ZERO,
            settings: PieMenuSettings::default(),
            key_held: true,
        }
    }

    pub fn with_position(mut self, pos: Pos2) -> Self {
        self.position = pos;
        self
    }
    /// Renders the pie menu and handles interactions.
    pub fn show(&mut self, ui: &mut Ui, current_mouse_pos: Option<Pos2>, key_down: bool) -> PieMenuResponse {
        if ui.input(|i| i.key_pressed(Key::Escape) || i.pointer.secondary_clicked()) {
            return PieMenuResponse::Dismissed;
        }
    
        let key_still_held = ui.input(|i| i.key_down(Key::S));
        let center = self.position;  // Fixed position, never updated after creation
    
        // Draw base menu circle
        ui.painter().circle_filled(center, 50.0, Color32::from_gray(30));
    
        // Update selection based on mouse angle
        if let Some(mouse_pos) = current_mouse_pos {
            let mouse_vector = mouse_pos - center;
            let distance = mouse_vector.length();
            
            // Only update selection if outside threshold
            if distance > self.settings.threshold {
                let angle = mouse_vector.y.atan2(mouse_vector.x);
                self.selected_index = self.buttons.iter()
                    .map(|(dir, button)| {
                        let button_angle = button.direction.y.atan2(button.direction.x);
                        let angle_diff = ((angle - button_angle + std::f32::consts::PI) % (2.0 * std::f32::consts::PI) - std::f32::consts::PI).abs();
                        (dir.clone(), angle_diff)
                    })
                    .min_by(|a, b| a.1.partial_cmp(&b.1).unwrap())
                    .map(|(dir, _)| dir);
            }
        }
    
        // Draw selection indicator line
        if let Some(dir) = &self.selected_index {
            if let Some(button) = self.buttons.get(dir) {
                let highlight_end = center + button.direction * 80.0;
                ui.painter().line_segment(
                    [center, highlight_end],
                    egui::Stroke::new(3.0, Color32::YELLOW),
                );
            }
        }
    
        // Draw buttons
        for (dir, button) in &self.buttons {
            let offset = button.direction * 80.0;
            let button_pos = center + offset;
            let button_rect = Rect::from_center_size(button_pos, Vec2::new(60.0, 30.0));
    
            let color = if self.selected_index.as_ref() == Some(dir) {
                Color32::LIGHT_BLUE
            } else {
                button.color
            };
    
            ui.painter().rect_filled(button_rect, 5.0, color);
            ui.painter().text(
                button_pos,
                egui::Align2::CENTER_CENTER,
                &button.label,
                egui::FontId::default(),
                Color32::BLACK,
            );
        }
    
        // Handle key release
        if key_down != self.key_held {
            println!("Key state changed: held={}, down={}", self.key_held, key_down);
            if self.key_held {  // Key was held but now released
                if let Some(mouse_pos) = current_mouse_pos {
                    let distance_to_center = (mouse_pos - center).length();
                    let held_duration = self.open_time.elapsed();
                    
                    println!("Release detected: duration={:?}, distance={}", held_duration, distance_to_center);
                    println!("Threshold={}, timeout={:?}", self.settings.threshold, self.settings.key_timeout);
    
                    if distance_to_center <= self.settings.threshold {
                        if held_duration > self.settings.key_timeout {
                            println!("Dismissing due to timeout");
                            return PieMenuResponse::Dismissed;
                        }
                        println!("Keeping menu open - quick release within threshold");
                    } else if let Some(dir) = &self.selected_index {
                        println!("Selecting direction: {}", dir);
                        return PieMenuResponse::Selected(dir.clone());
                    }
                }
            }
        }
        self.key_held = key_down;
    
        self.key_held = key_still_held;
        PieMenuResponse::None
    }pub fn with_settings(mut self, settings: PieMenuSettings) -> Self {
        self.settings = settings;
        self
    }
}